<taglib xmlns="jakarta.ee" version="3.0">
	<tlib-version>1.0</tlib-version>
	<short-name>GreetTag</short-name>
	<tag>
		<name>greet</name>
		<tag-class>com.mphasis.productmanagerapp.customtags.GreetTag</tag-class>
		<body-content>empty</body-content>
	
	<attribute>
			<name>fname</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		</tag>
</taglib>